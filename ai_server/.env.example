AI_SERVER_HOST=127.0.0.1
AI_SERVER_PORT=9000
AI_SERVER_DEBUG=true

UPLOADS_BASE_DIR=../FitApp/uploads
TRYON_OUTPUT_DIR=../FitApp/uploads/tryon

# fal.ai credentials and settings for virtual try-on.
# Never commit a real FAL_KEY.
FAL_KEY=your_fal_key_here
TRYON_PROVIDER=fal
FAL_TRYON_MODEL=fal-ai/fashn/tryon/v1.5
FAL_TRYON_CATEGORY=auto
FAL_TRYON_MODE=quality
FAL_GARMENT_PHOTO_TYPE=auto
FAL_MODERATION_LEVEL=permissive
FAL_NUM_SAMPLES=1
FAL_SEGMENTATION_FREE=true
FAL_OUTPUT_FORMAT=png
