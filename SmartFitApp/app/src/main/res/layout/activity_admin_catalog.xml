<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="@dimen/card_padding"
            android:text="Admin Catalog"
            style="@style/Text.ScreenTitle" />

        <!-- Mode toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/large_gap"
            android:orientation="horizontal">

            <Button
                android:id="@+id/updateModeButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:text="Update Item"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/addModeButton"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="@dimen/small_gap"
                android:layout_weight="1"
                android:text="Add Item"
                android:textAllCaps="false" />

        </LinearLayout>

        <!-- Current Available section (for update mode) -->
        <LinearLayout
            android:id="@+id/currentAvailableSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/large_gap"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/element_gap"
                android:text="Current Available"
                style="@style/Text.SectionTitle" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/itemsRecyclerView"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>

        <!-- Section: Item Details -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/element_gap"
            android:text="Item Details"
            style="@style/Text.SectionTitle" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Name">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/nameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/element_gap"
            android:hint="Description">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/descriptionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/card_padding"
            android:layout_marginBottom="4dp"
            android:text="Category"
            style="@style/Text.Label" />

        <Spinner
            android:id="@+id/categorySpinner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_spinner_outlined" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/element_gap"
            android:layout_marginBottom="4dp"
            android:text="Gender"
            style="@style/Text.Label" />

        <Spinner
            android:id="@+id/genderSpinner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_spinner_outlined" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/element_gap"
            android:hint="Brand">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/brandInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Image picker -->
        <TextView
            android:id="@+id/selectedImageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/card_padding"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/selectedImageCard"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginTop="@dimen/small_gap"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/small_radius"
            app:cardElevation="1dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/image_placeholder">

            <ImageView
                android:id="@+id/selectedImagePreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:contentDescription="Selected catalog image"
                android:padding="8dp"
                android:scaleType="fitCenter" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Section: Size Chart -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/large_gap"
            android:layout_marginBottom="@dimen/card_padding"
            android:background="@color/divider" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/element_gap"
            android:text="Size Chart"
            style="@style/Text.SectionTitle" />

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Sizes (comma separated)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/chartSizesInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <CheckBox
            android:id="@+id/activeCheckbox"
            android:layout_width="match_parent"
            android:layout_height="@dimen/touch_target"
            android:layout_marginTop="@dimen/element_gap"
            android:text="Available"
            android:textColor="@color/on_surface"
            android:textSize="14sp" />

        <Button
            android:id="@+id/saveButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/element_gap"
            android:text="Save Item"
            android:textAllCaps="false" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/element_gap"
            android:textSize="13sp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/small_gap"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
