<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:text="Preferences"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#6750A4" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preferred Size System"
            android:textColor="#888888"
            android:textSize="12sp" />
        <Spinner
            android:id="@+id/sizeSystemSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preferred Fit"
            android:textColor="#888888"
            android:textSize="12sp" />
        <Spinner
            android:id="@+id/fitSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preferred Gender Category"
            android:textColor="#888888"
            android:textSize="12sp" />
        <Spinner
            android:id="@+id/genderCategorySpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Preferred Clothing Categories"
            android:textColor="#888888"
            android:textSize="12sp" />
        <LinearLayout
            android:id="@+id/categoriesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="vertical" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Default Image Type"
            android:textColor="#888888"
            android:textSize="12sp" />
        <Spinner
            android:id="@+id/imageTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="12dp" />

        <Switch
            android:id="@+id/cameraSwitch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Camera enabled"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/saveImagesSwitch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save uploaded images"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/saveMeasurementsSwitch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save measurement history"
            android:textSize="15sp" />

        <Switch
            android:id="@+id/saveTryOnSwitch"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Save try-on history"
            android:textSize="15sp" />

        <CheckBox
            android:id="@+id/dataConsentCheckbox"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Data usage consent"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="13sp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/saveButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Save Preferences"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button" />

        <Button
            android:id="@+id/resetButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            android:text="Reset to Defaults"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button.OutlinedButton" />

    </LinearLayout>
</ScrollView>
