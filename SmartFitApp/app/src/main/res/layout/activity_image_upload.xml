<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:paddingStart="@dimen/screen_padding"
        android:paddingEnd="@dimen/screen_padding"
        android:paddingBottom="40dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="@dimen/card_padding"
            android:text="Upload Photo"
            style="@style/Text.ScreenTitle" />

        <!-- Image Preview -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:layout_marginBottom="@dimen/card_padding"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="1dp"
            app:strokeColor="@color/outline_variant"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/image_placeholder">

            <ImageView
                android:id="@+id/previewImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:contentDescription="Image preview" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Source buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="@dimen/large_gap">

            <Button
                android:id="@+id/cameraButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/button_height"
                android:layout_marginEnd="@dimen/small_gap"
                android:text="Camera"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.OutlinedButton" />

            <Button
                android:id="@+id/galleryButton"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="@dimen/button_height"
                android:layout_marginStart="@dimen/small_gap"
                android:text="Gallery"
                android:textAllCaps="false"
                style="@style/Widget.Material3.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Image Type label + Spinner -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="Photo Type"
            style="@style/Text.Label" />

        <Spinner
            android:id="@+id/imageTypeSpinner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_spinner_outlined"
            android:layout_marginBottom="@dimen/card_padding" />

        <!-- Status message -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="13sp"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/small_gap"
            android:visibility="gone" />

        <Button
            android:id="@+id/uploadButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/element_gap"
            android:text="Upload Photo"
            android:textAllCaps="false"
            style="@style/Widget.Material3.Button" />

    </LinearLayout>
</ScrollView>
